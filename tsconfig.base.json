{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@tesseract/adopter-scan": [
        "src/internal/packages/@tesseract/adopter-scan/src/index.ts"
      ],
      "@tesseract/checkpointer-fs": [
        "src/internal/packages/@tesseract/checkpointer-fs/src/index.ts"
      ],
      "@tesseract/cli": [
        "src/internal/packages/@tesseract/cli/src/index.ts"
      ],
      "@tesseract/contract": [
        "src/internal/packages/@tesseract/contract/src/index.ts"
      ],
      "@tesseract/contract-runner-llm-judge": [
        "src/internal/packages/@tesseract/contract-runner-llm-judge/src/index.ts"
      ],
      "@tesseract/contract-runner-rego": [
        "src/internal/packages/@tesseract/contract-runner-rego/src/index.ts"
      ],
      "@tesseract/contract-style": [
        "src/internal/packages/@tesseract/contract-style/src/index.ts"
      ],
      "@tesseract/core": [
        "src/internal/packages/@tesseract/core/src/index.ts"
      ],
      "@tesseract/env-isolation": [
        "src/internal/packages/@tesseract/env-isolation/src/index.ts"
      ],
      "@tesseract/inbox": [
        "src/internal/packages/@tesseract/inbox/src/index.ts"
      ],
      "@tesseract/intervention": [
        "src/internal/packages/@tesseract/intervention/src/index.ts"
      ],
      "@tesseract/mcp-server": [
        "src/internal/packages/@tesseract/mcp-server/src/index.ts"
      ],
      "@tesseract/memory": [
        "src/internal/packages/@tesseract/memory/src/index.ts"
      ],
      "@tesseract/notifier": [
        "src/internal/packages/@tesseract/notifier/src/index.ts"
      ],
      "@tesseract/persona": [
        "src/internal/packages/@tesseract/persona/src/index.ts"
      ],
      "@tesseract/pipeline": [
        "src/internal/packages/@tesseract/pipeline/src/index.ts"
      ],
      "@tesseract/policy": [
        "src/internal/packages/@tesseract/policy/src/index.ts"
      ],
      "@tesseract/run-logger": [
        "src/internal/packages/@tesseract/run-logger/src/index.ts"
      ],
      "@tesseract/runner-cursor": [
        "src/internal/packages/@tesseract/runner-cursor/src/index.ts"
      ],
      "@tesseract/worktree": [
        "src/internal/packages/@tesseract/worktree/src/index.ts"
      ]
    }
  },
  "include": [
    "src/internal/packages/tesseract/src/**/*.ts",
    "src/internal/packages/@tesseract/*/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/dist",
    "**/node_modules"
  ]
}
