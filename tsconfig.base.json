{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@daedaline/adopter-scan": ["src/internal/packages/@daedaline/adopter-scan/src/index.ts"],
      "@daedaline/checkpointer-fs": ["src/internal/packages/@daedaline/checkpointer-fs/src/index.ts"],
      "@daedaline/cli": ["src/internal/packages/@daedaline/cli/src/index.ts"],
      "@daedaline/contract": ["src/internal/packages/@daedaline/contract/src/index.ts"],
      "@daedaline/contract-runner-llm-judge": ["src/internal/packages/@daedaline/contract-runner-llm-judge/src/index.ts"],
      "@daedaline/contract-runner-rego": ["src/internal/packages/@daedaline/contract-runner-rego/src/index.ts"],
      "@daedaline/contract-style": ["src/internal/packages/@daedaline/contract-style/src/index.ts"],
      "@daedaline/core": ["src/internal/packages/@daedaline/core/src/index.ts"],
      "@daedaline/env-isolation": ["src/internal/packages/@daedaline/env-isolation/src/index.ts"],
      "@daedaline/inbox": ["src/internal/packages/@daedaline/inbox/src/index.ts"],
      "@daedaline/intervention": ["src/internal/packages/@daedaline/intervention/src/index.ts"],
      "@daedaline/mcp-server": ["src/internal/packages/@daedaline/mcp-server/src/index.ts"],
      "@daedaline/memory": ["src/internal/packages/@daedaline/memory/src/index.ts"],
      "@daedaline/notifier": ["src/internal/packages/@daedaline/notifier/src/index.ts"],
      "@daedaline/persona": ["src/internal/packages/@daedaline/persona/src/index.ts"],
      "@daedaline/pipeline": ["src/internal/packages/@daedaline/pipeline/src/index.ts"],
      "@daedaline/policy": ["src/internal/packages/@daedaline/policy/src/index.ts"],
      "@daedaline/run-logger": ["src/internal/packages/@daedaline/run-logger/src/index.ts"],
      "@daedaline/runner-cursor": ["src/internal/packages/@daedaline/runner-cursor/src/index.ts"],
      "@daedaline/worktree": ["src/internal/packages/@daedaline/worktree/src/index.ts"]
    }
  },
  "include": [
    "src/internal/packages/daedaline/src/**/*.ts",
    "src/internal/packages/@daedaline/*/src/**/*.ts"
  ],
  "exclude": ["node_modules", "**/dist", "**/node_modules"]
}
