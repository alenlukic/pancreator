{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@pancreator/adopter-scan": ["pancreator/lib/internal/packages/@pancreator/adopter-scan/src/index.ts"],
      "@pancreator/checkpointer-fs": ["pancreator/lib/internal/packages/@pancreator/checkpointer-fs/src/index.ts"],
      "@pancreator/cli": ["pancreator/lib/internal/packages/@pancreator/cli/src/index.ts"],
      "@pancreator/contract": ["pancreator/lib/internal/packages/@pancreator/contract/src/index.ts"],
      "@pancreator/contract-style": ["pancreator/lib/internal/packages/@pancreator/contract-style/src/index.ts"],
      "@pancreator/core": ["pancreator/lib/internal/packages/@pancreator/core/src/index.ts"],
      "@pancreator/env-isolation": ["pancreator/lib/internal/packages/@pancreator/env-isolation/src/index.ts"],
      "@pancreator/inbox": ["pancreator/lib/internal/packages/@pancreator/inbox/src/index.ts"],
      "@pancreator/intervention": ["pancreator/lib/internal/packages/@pancreator/intervention/src/index.ts"],
      "@pancreator/mcp-server": ["pancreator/lib/internal/packages/@pancreator/mcp-server/src/index.ts"],
      "@pancreator/memory": ["pancreator/lib/internal/packages/@pancreator/memory/src/index.ts"],
      "@pancreator/notifier": ["pancreator/lib/internal/packages/@pancreator/notifier/src/index.ts"],
      "@pancreator/persona": ["pancreator/lib/internal/packages/@pancreator/persona/src/index.ts"],
      "@pancreator/pipeline": ["pancreator/lib/internal/packages/@pancreator/pipeline/src/index.ts"],
      "@pancreator/policy": ["pancreator/lib/internal/packages/@pancreator/policy/src/index.ts"],
      "@pancreator/run-logger": ["pancreator/lib/internal/packages/@pancreator/run-logger/src/index.ts"],
      "@pancreator/runner-cursor": ["pancreator/lib/internal/packages/@pancreator/runner-cursor/src/index.ts"],
      "@pancreator/worktree": ["pancreator/lib/internal/packages/@pancreator/worktree/src/index.ts"]
    }
  },
  "include": ["pancreator/lib/internal/packages/@pancreator/*/src/**/*.ts"],
  "exclude": ["node_modules", "**/dist", "**/node_modules"]
}
