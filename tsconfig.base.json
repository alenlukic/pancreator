{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@tesseract/adopter-scan": [
        "packages/@tesseract/adopter-scan/src/index.ts"
      ],
      "@tesseract/checkpointer-fs": [
        "packages/@tesseract/checkpointer-fs/src/index.ts"
      ],
      "@tesseract/cli": ["packages/@tesseract/cli/src/index.ts"],
      "@tesseract/contract": ["packages/@tesseract/contract/src/index.ts"],
      "@tesseract/contract-runner-llm-judge": [
        "packages/@tesseract/contract-runner-llm-judge/src/index.ts"
      ],
      "@tesseract/contract-runner-rego": [
        "packages/@tesseract/contract-runner-rego/src/index.ts"
      ],
      "@tesseract/contract-style": [
        "packages/@tesseract/contract-style/src/index.ts"
      ],
      "@tesseract/core": ["packages/@tesseract/core/src/index.ts"],
      "@tesseract/env-isolation": [
        "packages/@tesseract/env-isolation/src/index.ts"
      ],
      "@tesseract/inbox": ["packages/@tesseract/inbox/src/index.ts"],
      "@tesseract/intervention": [
        "packages/@tesseract/intervention/src/index.ts"
      ],
      "@tesseract/mcp-server": [
        "packages/@tesseract/mcp-server/src/index.ts"
      ],
      "@tesseract/memory": ["packages/@tesseract/memory/src/index.ts"],
      "@tesseract/notifier": [
        "packages/@tesseract/notifier/src/index.ts"
      ],
      "@tesseract/persona": ["packages/@tesseract/persona/src/index.ts"],
      "@tesseract/pipeline": [
        "packages/@tesseract/pipeline/src/index.ts"
      ],
      "@tesseract/policy": ["packages/@tesseract/policy/src/index.ts"],
      "@tesseract/run-logger": [
        "packages/@tesseract/run-logger/src/index.ts"
      ],
      "@tesseract/runner-cursor": [
        "packages/@tesseract/runner-cursor/src/index.ts"
      ],
      "@tesseract/worktree": [
        "packages/@tesseract/worktree/src/index.ts"
      ]
    }
  },
  "include": [
    "packages/tesseract/src/**/*.ts",
    "packages/@tesseract/*/src/**/*.ts"
  ],
  "exclude": ["node_modules", "**/dist", "**/node_modules"]
}
