{
  "name": "pancreator-v2-prototype",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Cursor-native agent workflow harness prototype with a dependency-free runtime.",
  "bin": {
    "pan": "./bin/pan"
  },
  "scripts": {
    "build": "./bin/run-quiet -- ./bin/build",
    "pan": "npm run build && node dist/src/cli.js",
    "doctor": "npm run build && node dist/src/cli.js doctor",
    "validate": "npm run build && node dist/src/cli.js validate",
    "format": "./bin/run-quiet -- prettier --write .",
    "format:check": "./bin/run-quiet -- prettier --check .",
    "typecheck": "./bin/run-quiet -- tsc --noEmit",
    "lint": "./bin/run-quiet -- ./bin/lint",
    "validate:chat-markdown": "./bin/validate-chat-markdown",
    "test": "npm run build && ./bin/run-quiet -- node --test dist/tests/**/*.test.js",
    "test:unit": "npm run build && ./bin/run-quiet -- node --test dist/tests/unit/*.test.js",
    "test:migrations": "npm run build && ./bin/run-quiet -- node --test dist/tests/migrations/*.test.js",
    "test:integration": "npm run build && ./bin/run-quiet -- node --test dist/tests/integration/*.test.js",
    "test:regression": "npm run build && ./bin/run-quiet -- node --test dist/tests/regression/*.test.js",
    "test:coverage": "npm run build && ./bin/run-quiet -- node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=70 --test-coverage-include=dist/src/lib/** dist/tests/**/*.test.js",
    "check": "./bin/run-quiet -- ./bin/check"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
