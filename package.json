{
  "name": "pancreator",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "lint": "eslint . --ignore-pattern 'pancreator/client/**'",
    "lint:deps": "node pancreator/lib/internal/tools/checks/check-workspace-contracts.mjs",
    "typecheck": "tsc -p tsconfig.base.json",
    "attw": "turbo run attw --output-logs=errors-only",
    "publint": "turbo run publint --output-logs=errors-only",
    "check:workspace-contracts": "node pancreator/lib/internal/tools/checks/check-workspace-contracts.mjs",
    "migration:test": "node --test pancreator/tests/migrate-timestamp-naming.test.mjs pancreator/tests/migrate-inbox-convention.test.mjs",
    "repo:structure:test": "node --test pancreator/tests/repo-structure.test.mjs",
    "governance:audit": "node pancreator/lib/internal/tools/governance/audit-governance-usage.mjs",
    "governance:contract-bundles": "node pancreator/lib/internal/tools/contracts/generate-minimal-contract-bundles.mjs",
    "governance:projection-drift": "node pancreator/lib/internal/tools/checks/check-cursor-projection-drift.mjs",
    "governance:persona-rfc2119": "node pancreator/lib/internal/tools/checks/check-persona-required-context-rfc2119.mjs",
    "governance:test": "node --test pancreator/tests/agent-document-registry-integrity.test.mjs pancreator/tests/model-escalation-completeness.test.mjs && node pancreator/lib/internal/tools/checks/check-persona-required-context-rfc2119.mjs",
    "test": "turbo run test && node --test pancreator/tests/repo-structure.test.mjs pancreator/tests/migrate-json-formatting.test.mjs pancreator/tests/migrate-timestamp-naming.test.mjs pancreator/tests/migrate-inbox-convention.test.mjs pancreator/tests/agent-document-registry-integrity.test.mjs pancreator/tests/model-escalation-completeness.test.mjs",
    "test:run-logger-conformance": "node --test pancreator/tests/run-logger-conformance/*.test.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/cli": "catalog:",
    "@eslint/js": "catalog:",
    "@pancreator/cli": "workspace:*",
    "@pancreator/mcp-server": "workspace:*",
    "@pancreator/runner-cursor": "workspace:*",
    "eslint": "catalog:",
    "publint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "yaml": "catalog:",
    "ajv": "^8.20.0",
    "@cursor/sdk": "1.0.13"
  },
  "optionalDependencies": {
    "@cursor/sdk-darwin-arm64": "1.0.13",
    "@cursor/sdk-darwin-x64": "1.0.13",
    "@cursor/sdk-linux-arm64": "1.0.13",
    "@cursor/sdk-linux-x64": "1.0.13",
    "@cursor/sdk-win32-x64": "1.0.13"
  },
  "dependencies": {
    "@langchain/langgraph": "1.3.2",
    "@langchain/langgraph-checkpoint": "1.0.2"
  }
}
