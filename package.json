{
  "name": "pancreator-v2-prototype",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Cursor-native agent workflow harness prototype with a dependency-free runtime.",
  "bin": {
    "pan": "./bin/pan"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "pan": "npm run build --silent && node dist/src/cli.js",
    "doctor": "npm run build --silent && node dist/src/cli.js doctor",
    "validate": "npm run build --silent && node dist/src/cli.js validate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "lint": "bash scripts/lint.sh",
    "test": "npm run build --silent && node --test dist/tests/**/*.test.js",
    "test:unit": "npm run build --silent && node --test dist/tests/unit/*.test.js",
    "test:integration": "npm run build --silent && node --test dist/tests/integration/*.test.js",
    "test:regression": "npm run build --silent && node --test dist/tests/regression/*.test.js",
    "test:coverage": "npm run build --silent && node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=70 --test-coverage-include='dist/src/lib/**' dist/tests/**/*.test.js",
    "check": "npm run lint && npm run build && npm run validate && npm test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
