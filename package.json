{
  "name": "daedaline",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "lint": "eslint . --ignore-pattern client",
    "lint:deps": "node src/internal/tools/check-phase-0a-scaffold.mjs",
    "typecheck": "tsc -p tsconfig.base.json",
    "attw": "turbo run attw",
    "publint": "turbo run publint",
    "check:phase0a": "node src/internal/tools/check-phase-0a-scaffold.mjs",
    "migration:test": "node --test tests/migrate-timestamp-naming.test.mjs tests/migrate-inbox-convention.test.mjs",
    "context:budget": "node src/internal/tools/context-budget-report.mjs",
    "context:budget:test": "node --test tests/context-budget-report.test.mjs",
    "repo:structure:test": "node --test tests/repo-structure.test.mjs",
    "test": "turbo run test && node --test tests/repo-structure.test.mjs tests/migrate-json-formatting.test.mjs tests/migrate-timestamp-naming.test.mjs tests/migrate-inbox-convention.test.mjs tests/context-budget-report.test.mjs",
    "test:run-logger-conformance": "node --test tests/run-logger-conformance/*.test.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@changesets/cli": "catalog:",
    "@eslint/js": "catalog:",
    "@daedaline/cli": "workspace:*",
    "@daedaline/mcp-server": "workspace:*",
    "eslint": "catalog:",
    "publint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "yaml": "catalog:"
  },
  "dependencies": {
    "@langchain/langgraph": "1.3.2",
    "@langchain/langgraph-checkpoint": "1.0.2"
  }
}
