{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pancreator://schemas/greenfield-us9-evidence/v1",
  "title": "Greenfield US-9 evidence artifact",
  "description": "In-repo evidence contract for init-greenfield pipeline runs against an external monorepo. Evaluators MUST judge pass, fail, or fail-with-gaps without opening the target repository.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "metadata",
    "provenance",
    "checklist",
    "verdict_preconditions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "artifact_kind": {
      "type": "string",
      "const": "greenfield-us9-evidence"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature_id", "task_id", "target_repo", "pipeline_id", "captured_at_iso", "project_root"],
      "properties": {
        "project_root": {
          "type": "string",
          "enum": [".", ".pancreator"]
        },
        "feature_id": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "target_repo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "git_remote": {
              "type": "string"
            }
          }
        },
        "pipeline_id": {
          "type": "string",
          "const": "init-greenfield"
        },
        "captured_at_iso": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cli_commands", "pipeline_stages_completed"],
      "properties": {
        "cli_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pipeline_stages_completed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["scaffold", "spec", "plan"]
          },
          "uniqueItems": true
        },
        "operator_personas": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "checklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agents_md_present",
        "handbook_seeds_present",
        "persona_roster_present",
        "feature_spec_authored",
        "plan_touch_set_authored",
        "no_overwritten_existing_files"
      ],
      "properties": {
        "agents_md_present": {
          "type": "boolean"
        },
        "handbook_seeds_present": {
          "type": "boolean"
        },
        "persona_roster_present": {
          "type": "boolean"
        },
        "feature_spec_authored": {
          "type": "boolean"
        },
        "plan_touch_set_authored": {
          "type": "boolean"
        },
        "no_overwritten_existing_files": {
          "type": "boolean"
        }
      }
    },
    "verdict_preconditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_stages_completed", "required_checklist_pass_count"],
      "properties": {
        "minimum_stages_completed": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "required_checklist_pass_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        }
      }
    }
  }
}
