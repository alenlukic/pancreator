{
  "name": "client",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next node_modules",
    "predev": "pnpm -w exec turbo run build --filter=client^...",
    "dev": "next dev --port 3000",
    "dev:clean": "pnpm clean && pnpm install && pnpm dev",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@pancreator/core": "workspace:*",
    "@pancreator/intervention": "workspace:*",
    "@pancreator/persona": "workspace:*",
    "@pancreator/runner-cursor": "workspace:*",
    "@pancreator/scheduler": "workspace:*",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "@eslint/js": "catalog:",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "catalog:",
    "jsdom": "^26.1.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "vitest": "catalog:"
  }
}
