{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pancreator://schemas/model-escalation-config/v1",
  "title": "Pancreator model escalation config",
  "type": "object",
  "additionalProperties": false,
  "required": ["active_config", "configs"],
  "properties": {
    "active_config": {
      "type": "string",
      "minLength": 1
    },
    "configs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["personas"],
        "properties": {
          "personas": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "object",
              "minProperties": 1,
              "required": ["default"],
              "properties": {
                "default": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "patternProperties": {
                "^[0-9]+$": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          }
        }
      }
    }
  }
}
