{
  "schema_version": 2,
  "policy": "CONTRACT-001",
  "regeneration_command": "./bin/pan models --sync",
  "projections": [
    {
      "id": "cursor-agents",
      "source": "library/cursor/agents/{persona}.md",
      "target": ".cursor/agents/{persona}.md",
      "installation_modes": ["self_development", "embedded"],
      "generated_fields": ["frontmatter.model"],
      "transforms": ["installation-paths"]
    },
    {
      "id": "cursor-commands",
      "source": "library/cursor/commands/{command}.md",
      "target": ".cursor/commands/{command}.md",
      "installation_modes": ["self_development", "embedded"],
      "generated_fields": [],
      "transforms": ["installation-paths"]
    },
    {
      "id": "cursor-self-development-rule",
      "source": "library/cursor/rules/pancreator-self-development.mdc",
      "target": ".cursor/rules/pancreator.mdc",
      "installation_modes": ["self_development"],
      "generated_fields": [],
      "transforms": []
    },
    {
      "id": "cursor-embedded-rule",
      "source": "library/cursor/rules/pancreator-embedded.mdc",
      "target": ".cursor/rules/pancreator.mdc",
      "installation_modes": ["embedded"],
      "generated_fields": [],
      "transforms": []
    },
    {
      "id": "cursor-visual-qa-rule",
      "source": "library/cursor/rules/visual-qa-isolation.mdc",
      "target": ".cursor/rules/visual-qa-isolation.mdc",
      "installation_modes": ["self_development", "embedded"],
      "generated_fields": [],
      "transforms": []
    },
    {
      "id": "cursor-mcp",
      "source": "library/cursor/mcp.json",
      "target": ".cursor/mcp.json",
      "installation_modes": ["self_development"],
      "generated_fields": [],
      "transforms": []
    }
  ]
}
