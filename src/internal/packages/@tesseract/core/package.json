{
  "name": "@tesseract/core",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json",
    "attw": "attw --pack . --profile esm-only",
    "publint": "publint",
    "test": "node -e \"process.exit(0)\""
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "publint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
