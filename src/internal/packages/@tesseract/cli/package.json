{
  "name": "@tesseract/cli",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tess": "./bin/tess.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["bin", "dist"],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "attw": "attw --pack . --profile esm-only",
    "publint": "publint"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph-checkpoint": "1.0.2",
    "@tesseract/checkpointer-fs": "workspace:*",
    "@tesseract/core": "workspace:*",
    "@tesseract/inbox": "workspace:*",
    "@tesseract/intervention": "workspace:*",
    "@tesseract/pipeline": "workspace:*",
    "@tesseract/run-logger": "workspace:*",
    "@tesseract/runner-cursor": "workspace:*",
    "commander": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@types/node": "^22.10.0",
    "publint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
