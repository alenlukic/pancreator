{
  "name": "@tesseract/cli",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tess": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "attw": "attw --pack . --profile esm-only",
    "publint": "publint"
  },
  "dependencies": {
    "@tesseract/core": "workspace:*",
    "@tesseract/inbox": "workspace:*",
    "@tesseract/intervention": "workspace:*",
    "@tesseract/pipeline": "workspace:*",
    "@tesseract/run-logger": "workspace:*",
    "commander": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@types/node": "^22.10.0",
    "publint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
