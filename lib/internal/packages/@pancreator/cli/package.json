{
  "name": "@pancreator/cli",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pan": "./bin/pan.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["bin", "dist"],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "attw": "attw --pack . --profile esm-only",
    "publint": "publint"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph-checkpoint": "1.0.2",
    "@pancreator/checkpointer-fs": "workspace:*",
    "@pancreator/core": "workspace:*",
    "@pancreator/inbox": "workspace:*",
    "@pancreator/intervention": "workspace:*",
    "@pancreator/persona": "workspace:*",
    "@pancreator/pipeline": "workspace:*",
    "@pancreator/run-logger": "workspace:*",
    "@pancreator/runner-cursor": "workspace:*",
    "@pancreator/scheduler": "workspace:*",
    "commander": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@types/node": "^22.10.0",
    "publint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
