{
  "slug": "inspect",
  "title": "Inspect repository",
  "persona": "reviewer",
  "prompt_path": "library/workflows/preflight/prompts/inspect.md",
  "workspace_policy": "read_only",
  "gate": "stage_verdict",
  "context": {
    "request": "required"
  },
  "required_data": {
    "inspection": "object",
    "inspection.findings": "array",
    "inspection.verdict": "string"
  },
  "criteria": [
    {
      "id": "preflight.validate",
      "type": "shell",
      "hard": true,
      "statement": "Harness configuration validates.",
      "command": "\"$PANCREATOR_ROOT/bin/pan\" validate",
      "timeout_ms": 120000
    },
    {
      "id": "preflight.tests",
      "type": "shell",
      "hard": true,
      "statement": "Harness tests pass.",
      "command": "npm --prefix \"$PANCREATOR_ROOT\" test",
      "timeout_ms": 300000
    }
  ],
  "transitions": {
    "success": "succeeded",
    "failure": "failed",
    "blocked": "paused"
  }
}
