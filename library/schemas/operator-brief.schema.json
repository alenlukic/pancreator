{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pancreator.local/schemas/operator-brief.schema.json",
  "title": "Pancreator operator brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "brief_type", "title", "sections"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "brief_type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "subtitle": {
      "type": "string",
      "maxLength": 280
    },
    "eyebrow": {
      "type": "string",
      "maxLength": 80
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "maxLength": 300
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      },
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/section"
            },
            {
              "properties": {
                "semantic": {
                  "const": "executive-summary"
                }
              }
            }
          ]
        }
      ]
    }
  },
  "$defs": {
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "tone": {
          "enum": ["neutral", "positive", "warning", "negative", "info"]
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 60
        },
        "value": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          ]
        },
        "semantic": {
          "type": "string",
          "minLength": 1
        },
        "placement": {
          "enum": ["meta", "body", "footer"]
        },
        "emphasis": {
          "enum": ["normal", "muted", "strong"]
        },
        "href": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "style": {
          "enum": ["primary", "secondary", "danger"]
        }
      },
      "oneOf": [
        {
          "required": ["href"],
          "not": {
            "required": ["command"]
          }
        },
        {
          "required": ["command"],
          "not": {
            "required": ["href"]
          }
        }
      ]
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "body": {
          "type": "string",
          "maxLength": 2000
        },
        "body_html": {
          "type": "string",
          "maxLength": 12000
        }
      },
      "not": {
        "required": ["body", "body_html"]
      }
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "lede": {
          "type": "string",
          "maxLength": 600
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "urgency": {
          "$ref": "#/$defs/status"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "body": {
          "type": "string",
          "maxLength": 6000
        },
        "body_html": {
          "type": "string",
          "maxLength": 30000
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/item"
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          }
        }
      },
      "not": {
        "required": ["body", "body_html"]
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["semantic", "title", "cards"],
      "properties": {
        "semantic": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 70
        },
        "description": {
          "type": "string",
          "maxLength": 280
        },
        "layout": {
          "enum": ["stack", "grid"]
        },
        "cards": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/card"
          }
        }
      }
    }
  }
}
