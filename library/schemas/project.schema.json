{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pancreator://project/v1",
  "title": "Pancreator project configuration",
  "description": "Workspace identity, state root, tracking patterns, and named persona-to-model mappings for a Pancreator workspace.",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "state_root": {
      "type": "string",
      "minLength": 1
    },
    "tracking": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "active_config": {
      "type": "string",
      "minLength": 1
    },
    "$operator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "configs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["personas"],
        "additionalProperties": false,
        "properties": {
          "summary": {
            "type": "string"
          },
          "personas": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
