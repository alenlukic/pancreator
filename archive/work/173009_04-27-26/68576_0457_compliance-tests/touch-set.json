{
  "feature_id": "compliance-tests",
  "paths": [
    "lib/internal/tests/compliance/schemas/latest.yaml",
    "lib/internal/tests/compliance/schemas/v1.yaml",
    "lib/internal/tests/compliance/high-remediation-blocking.yaml",
    "lib/internal/tests/compliance/medium-backlog-default-off.yaml",
    "lib/internal/tests/compliance/low-warning-emission.yaml",
    "lib/memory/features/compliance-tests/manual-runbook.md",
    "lib/memory/features/compliance-tests/severity-routing.md",
    "lib/memory/features/compliance-tests/run-template.json",
    "AGENTS.md",
    "lib/memory/backlog/index.yaml"
  ],
  "symbols": [],
  "tests": [
    {
      "id": "schema-location-and-shape",
      "type": "artifact-validation",
      "target": "lib/internal/tests/compliance/schemas/latest.yaml",
      "expectation": "Latest schema exists in canonical location and validates compliance descriptor structure."
    },
    {
      "id": "rejected-duplicate-location-cleanup",
      "type": "artifact-validation",
      "target": "lib/memory/features/compliance-tests/contracts/",
      "expectation": "No duplicate compliance descriptors or schemas remain under the feature contracts path; canonical assets live only under lib/internal/tests/compliance/."
    },
    {
      "id": "manual-agent-invocation-policy",
      "type": "artifact-validation",
      "target": "lib/memory/features/compliance-tests/manual-runbook.md",
      "expectation": "Runbook encodes operator and agent manual invocation and marks scheduled automation as deferred."
    },
    {
      "id": "severity-routing-policy",
      "type": "review-check",
      "target": "lib/memory/features/compliance-tests/severity-routing.md",
      "expectation": "Routing text matches high/medium/low obligations from feature spec."
    },
    {
      "id": "agents-trigger-guidance-update",
      "type": "review-check",
      "target": "AGENTS.md",
      "expectation": "Policy guidance defines when agents trigger compliance runs for structure changes and manual invocations."
    }
  ]
}
