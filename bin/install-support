#!/usr/bin/env node
import { createHash } from 'node:crypto'
import {
  cpSync,
  copyFileSync,
  existsSync,
  mkdirSync,
  readFileSync,
  readdirSync,
  rmSync,
  writeFileSync,
} from 'node:fs'
import path from 'node:path'
import { fileURLToPath, pathToFileURL } from 'node:url'

function fail(message) {
  process.stderr.write(`${message}\n`)
  process.exit(1)
}

function option(name) {
  const index = process.argv.indexOf(name)

  if (index === -1) {
    return null
  }

  const value = process.argv[index + 1]

  if (!value || value.startsWith('--')) {
    fail(`${name} requires a value`)
  }

  return value
}

function requiredOption(name) {
  return option(name) ?? fail(`${name} is required`)
}

function readJson(filePath) {
  return JSON.parse(readFileSync(filePath, 'utf8'))
}

function writeJson(filePath, value) {
  mkdirSync(path.dirname(filePath), { recursive: true })
  writeFileSync(filePath, `${JSON.stringify(value, null, 2)}\n`)
}

function sha256(value) {
  return createHash('sha256').update(value).digest('hex')
}

function projectCursorContent(content, relative) {
  let projected = content
    .replaceAll('./bin/pan', './.pancreator/bin/pan')
    .replaceAll('`library/', '`.pancreator/library/')
    .replaceAll('`governance/', '`.pancreator/governance/')
    .replaceAll('npm run validate', 'npm --prefix .pancreator run validate')
    .replaceAll('npm run check', 'npm --prefix .pancreator run check')
    .replaceAll(
      'Read `AGENTS.md`',
      "Read the target repository's `AGENTS.md` when present and `.pancreator/AGENTS.md`",
    )
    .replaceAll(
      'read `AGENTS.md`',
      "read the target repository's `AGENTS.md` when present and `.pancreator/AGENTS.md`",
    )

  if (
    relative.startsWith('.cursor/agents/') ||
    relative === '.cursor/commands/pan-write-pr.md' ||
    relative === '.cursor/commands/pan-build-briefs.md'
  ) {
    projected = projected.replaceAll('`docs/', '`.pancreator/docs/')
  }

  if (relative.startsWith('.cursor/agents/')) {
    projected = projected
      .replaceAll('`runtime/', '`.pancreator/runtime/')
      .replaceAll(' under `runtime/', ' under `.pancreator/runtime/')
      .replaceAll(' to `runtime/', ' to `.pancreator/runtime/')
  }

  if (relative === '.cursor/commands/pan-start.md') {
    projected = projected
      .replace('under `runtime/inbox/`.', 'under `.pancreator/runtime/inbox/`.')
      .replace(
        'write that object to a uniquely named JSON file under `runtime/inbox/`',
        'write that object to a uniquely named JSON file under `.pancreator/runtime/inbox/`',
      )
  }

  if (relative === '.cursor/commands/pan-decompose.md') {
    projected = projected.replace(
      'output path under `runtime/inbox/`',
      'output path under `.pancreator/runtime/inbox/`',
    )
  }

  if (relative === '.cursor/commands/pan-repair.md') {
    projected = projected.replace(
      'output path under `runtime/inbox/`',
      'output path under `.pancreator/runtime/inbox/`',
    )
  }

  return projected
}

function expandProjection(sourceRoot, projection) {
  const match = /\{([a-z_]+)\}/u.exec(projection.source)

  if (!match) {
    return [
      {
        source: path.join(sourceRoot, projection.source),
        relative: projection.target,
        variable: null,
        generatedFields: projection.generated_fields ?? [],
        transforms: projection.transforms ?? [],
      },
    ]
  }

  const token = match[0]
  const sourceDirectory = path.dirname(projection.source)
  const sourceBasename = path.basename(projection.source)
  const [prefix, suffix] = sourceBasename.split(token)
  const absoluteDirectory = path.join(sourceRoot, sourceDirectory)

  return readdirSync(absoluteDirectory, { withFileTypes: true })
    .filter(
      (entry) =>
        entry.isFile() &&
        entry.name.startsWith(prefix ?? '') &&
        entry.name.endsWith(suffix ?? ''),
    )
    .map((entry) => {
      const variable = entry.name.slice(
        (prefix ?? '').length,
        entry.name.length - (suffix ?? '').length,
      )

      return {
        source: path.join(absoluteDirectory, entry.name),
        relative: projection.target.replace(token, variable),
        variable,
        generatedFields: projection.generated_fields ?? [],
        transforms: projection.transforms ?? [],
      }
    })
}

function cursorSourceFiles(sourceRoot) {
  const manifest = readJson(
    path.join(
      sourceRoot,
      'governance',
      'registries',
      'projection_manifest.json',
    ),
  )

  if (manifest.schema_version !== 2 || !Array.isArray(manifest.projections)) {
    fail('Invalid governance/registries/projection_manifest.json')
  }

  for (const projection of manifest.projections) {
    if (
      !projection ||
      typeof projection.source !== 'string' ||
      projection.source.startsWith('.cursor/') ||
      typeof projection.target !== 'string' ||
      !projection.target.startsWith('.cursor/')
    ) {
      fail(
        'Projection sources MUST be canonical and targets MUST be under .cursor/',
      )
    }
  }

  return manifest.projections
    .filter(
      (projection) =>
        Array.isArray(projection.installation_modes) &&
        projection.installation_modes.includes('embedded'),
    )
    .flatMap((projection) => expandProjection(sourceRoot, projection))
    .sort((left, right) => left.relative.localeCompare(right.relative))
}

function personaModelsFromConfig(configPath) {
  const config = readJson(configPath)
  const active = config.configs?.[config.active_config]

  if (!active || typeof active.personas !== 'object') {
    fail('project.json active config does not define personas')
  }

  return active.personas
}

function personaModelsForProjection(personaConfigPath, sourceRoot) {
  const sourceConfigPath = path.join(sourceRoot, 'project.json')
  const sourceConfig = readJson(sourceConfigPath)

  if (!personaConfigPath) {
    return personaModelsFromConfig(sourceConfigPath)
  }

  const targetConfig = readJson(personaConfigPath)
  const activeConfigName =
    typeof targetConfig.active_config === 'string'
      ? targetConfig.active_config
      : sourceConfig.active_config
  const sourcePersonas =
    sourceConfig.configs?.[activeConfigName]?.personas ??
    sourceConfig.configs?.[sourceConfig.active_config]?.personas
  const targetPersonas = targetConfig.configs?.[activeConfigName]?.personas

  if (!sourcePersonas || typeof sourcePersonas !== 'object') {
    fail('project.json active config does not define personas')
  }

  if (!targetPersonas || typeof targetPersonas !== 'object') {
    return sourcePersonas
  }

  return { ...sourcePersonas, ...targetPersonas }
}

function mergeEmbeddedProjectConfig(source, existing) {
  const merged = {
    ...source,
    configs: { ...(existing.configs ?? {}) },
  }
  const activeConfig =
    typeof existing.active_config === 'string' &&
    existing.configs?.[existing.active_config]
      ? existing.active_config
      : source.active_config

  merged.active_config = activeConfig

  for (const [name, sourceConfig] of Object.entries(source.configs ?? {})) {
    if (typeof sourceConfig !== 'object' || sourceConfig === null) {
      continue
    }

    const existingConfig = merged.configs[name]

    if (!existingConfig || typeof existingConfig !== 'object') {
      merged.configs[name] = sourceConfig
      continue
    }

    merged.configs[name] = {
      ...sourceConfig,
      ...existingConfig,
      personas: {
        ...(typeof sourceConfig.personas === 'object'
          ? sourceConfig.personas
          : {}),
        ...(typeof existingConfig.personas === 'object'
          ? existingConfig.personas
          : {}),
      },
    }
  }

  return merged
}

const LANGUAGE_BUNDLE_MARKER = 'pancreator-target-language-handbooks'
const LANGUAGE_CODE_PERSONAS = new Set([
  'coder',
  'qa-tester',
  'reviewer',
  'spotfixer',
])

function isGeneratedLanguageRow(row) {
  return (
    row &&
    typeof row === 'object' &&
    row.generated_by === LANGUAGE_BUNDLE_MARKER
  )
}

function validLanguageBundle(existingRoot) {
  const policyPath = path.join(
    existingRoot,
    'governance',
    'policies',
    'LANG-001.json',
  )
  const handbookRoot = path.join(
    existingRoot,
    'governance',
    'handbooks',
    'target',
  )
  const lookupPath = path.join(
    existingRoot,
    'governance',
    'registries',
    'policy_lookup_table.json',
  )

  if (
    !existsSync(policyPath) ||
    !existsSync(handbookRoot) ||
    !existsSync(lookupPath)
  ) {
    return false
  }

  let policy
  let lookup

  try {
    policy = readJson(policyPath)
    lookup = readJson(lookupPath)
  } catch {
    return false
  }

  if (
    policy?.id !== 'LANG-001' ||
    policy?.generated_by !== LANGUAGE_BUNDLE_MARKER ||
    !Array.isArray(policy.guidance_sources) ||
    !Array.isArray(lookup?.rows)
  ) {
    return false
  }

  const sources = policy.guidance_sources
    .map((source) => (typeof source?.path === 'string' ? source.path : null))
    .filter(Boolean)
    .sort()
  const handbooks = readdirSync(handbookRoot, { withFileTypes: true })
    .filter((entry) => entry.isDirectory())
    .map((entry) => {
      const relative = `governance/handbooks/target/${entry.name}/style-guide.md`
      const absolute = path.join(existingRoot, relative)

      return existsSync(absolute) &&
        readFileSync(absolute, 'utf8').includes(
          `<!-- pancreator-target-language-handbook: ${entry.name} -->`,
        )
        ? relative
        : null
    })
    .filter(Boolean)
    .sort()

  if (
    sources.length === 0 ||
    sources.length !== handbooks.length ||
    sources.some((source, index) => source !== handbooks[index])
  ) {
    return false
  }

  const rows = lookup.rows.filter(isGeneratedLanguageRow)
  const personas = rows
    .filter(
      (row) =>
        Array.isArray(row.policies) &&
        row.policies.length === 1 &&
        row.policies[0] === 'LANG-001' &&
        typeof row.persona === 'string',
    )
    .map((row) => row.persona)

  return (
    rows.length === LANGUAGE_CODE_PERSONAS.size &&
    personas.length === LANGUAGE_CODE_PERSONAS.size &&
    personas.every((persona) => LANGUAGE_CODE_PERSONAS.has(persona)) &&
    new Set(personas).size === LANGUAGE_CODE_PERSONAS.size
  )
}

function preserveLanguageGovernance() {
  const existingRoot = path.resolve(requiredOption('--existing-root'))
  const stagingRoot = path.resolve(requiredOption('--staging-root'))

  if (!validLanguageBundle(existingRoot)) {
    return
  }

  const existingHandbooks = path.join(
    existingRoot,
    'governance',
    'handbooks',
    'target',
  )
  const stagedHandbooks = path.join(
    stagingRoot,
    'governance',
    'handbooks',
    'target',
  )
  cpSync(existingHandbooks, stagedHandbooks, { recursive: true, force: true })
  copyFileSync(
    path.join(existingRoot, 'governance', 'policies', 'LANG-001.json'),
    path.join(stagingRoot, 'governance', 'policies', 'LANG-001.json'),
  )

  const existingLookup = readJson(
    path.join(
      existingRoot,
      'governance',
      'registries',
      'policy_lookup_table.json',
    ),
  )
  const stagedLookupPath = path.join(
    stagingRoot,
    'governance',
    'registries',
    'policy_lookup_table.json',
  )
  const stagedLookup = readJson(stagedLookupPath)
  stagedLookup.rows = [
    ...stagedLookup.rows.filter((row) => !isGeneratedLanguageRow(row)),
    ...existingLookup.rows.filter(isGeneratedLanguageRow),
  ]
  writeJson(stagedLookupPath, stagedLookup)
}

function previousCursorFiles(markerPath) {
  if (!markerPath || !existsSync(markerPath)) {
    return new Map()
  }

  const marker = readJson(markerPath)
  const entries = Array.isArray(marker.cursor_files) ? marker.cursor_files : []

  return new Map(
    entries
      .filter(
        (entry) =>
          entry &&
          typeof entry.path === 'string' &&
          typeof entry.sha256 === 'string',
      )
      .map((entry) => [entry.path, entry.sha256]),
  )
}

function projectCursor() {
  const sourceRoot = path.resolve(requiredOption('--source-root'))
  const targetRoot = path.resolve(requiredOption('--target-root'))
  const manifestOut = path.resolve(requiredOption('--manifest-out'))
  const markerPath = option('--previous-marker')
  const backupRoot = option('--backup-root')
  const previous = previousCursorFiles(markerPath)
  const projected = []
  const backups = []
  const currentPaths = new Set()
  const personaConfigPath = option('--persona-config')
  const personaModels = personaModelsForProjection(
    personaConfigPath ? path.resolve(personaConfigPath) : null,
    sourceRoot,
  )

  for (const entry of cursorSourceFiles(sourceRoot)) {
    let content = readFileSync(entry.source, 'utf8')

    if (entry.generatedFields.includes('frontmatter.model')) {
      const model = personaModels[entry.variable]

      if (typeof model !== 'string' || model.length === 0) {
        fail(`No active model mapping for Cursor persona: ${entry.variable}`)
      }

      if (!content.includes('__PANCREATOR_MODEL__')) {
        fail(`${entry.source} is missing __PANCREATOR_MODEL__`)
      }

      content = content.replaceAll('__PANCREATOR_MODEL__', model)
    }

    if (entry.transforms.includes('installation-paths')) {
      content = projectCursorContent(content, entry.relative)
    }
    const destination = path.join(targetRoot, entry.relative)
    const digest = sha256(content)

    currentPaths.add(entry.relative)

    if (existsSync(destination)) {
      const existing = readFileSync(destination)
      const existingDigest = sha256(existing)
      const previousDigest = previous.get(entry.relative)
      const isOperatorFile = previousDigest === undefined
      const wasModifiedAfterInstall =
        previousDigest !== undefined && previousDigest !== existingDigest

      if (
        existingDigest !== digest &&
        (isOperatorFile || wasModifiedAfterInstall) &&
        backupRoot
      ) {
        const backupPath = path.join(path.resolve(backupRoot), entry.relative)

        mkdirSync(path.dirname(backupPath), { recursive: true })
        copyFileSync(destination, backupPath)
        backups.push(entry.relative)
      }
    }

    mkdirSync(path.dirname(destination), { recursive: true })
    writeFileSync(destination, content)
    projected.push({ path: entry.relative, sha256: digest })
  }

  for (const [relative, previousDigest] of previous) {
    if (currentPaths.has(relative)) {
      continue
    }

    const destination = path.join(targetRoot, relative)

    if (!existsSync(destination)) {
      continue
    }

    const existingDigest = sha256(readFileSync(destination))

    if (existingDigest === previousDigest) {
      rmSync(destination)
    }
  }

  writeJson(manifestOut, { cursor_files: projected, backups })
}

function normalizedCommands(profile) {
  if (!profile || !Array.isArray(profile.commands)) {
    return []
  }

  return profile.commands.map((command) =>
    typeof command === 'string'
      ? command.trim().replace(/\s+/gu, ' ')
      : command,
  )
}

function sameNonEmptyCommands(left, right) {
  const leftCommands = normalizedCommands(left)
  const rightCommands = normalizedCommands(right)

  return (
    leftCommands.length > 0 &&
    leftCommands.length === rightCommands.length &&
    leftCommands.every((command, index) => command === rightCommands[index])
  )
}

function migrateRepositoryChecks() {
  const configPath = path.resolve(requiredOption('--config'))
  const templatePath = path.resolve(requiredOption('--template'))
  const backupRoot = path.resolve(requiredOption('--backup-root'))
  const config = readJson(configPath)
  const template = readJson(templatePath)

  if (
    config.schema_version !== 1 ||
    !config.profiles ||
    typeof config.profiles !== 'object' ||
    template.schema_version !== 1 ||
    !template.profiles ||
    typeof template.profiles !== 'object'
  ) {
    fail(
      'Repository-check configuration migration requires schema_version 1 profile maps',
    )
  }

  const original = `${JSON.stringify(config, null, 2)}\n`
  const notes = []

  for (const [name, profile] of Object.entries(template.profiles)) {
    if (!(name in config.profiles)) {
      config.profiles[name] = profile
      notes.push(`Added missing ${name} repository-check profile.`)
    }
  }

  if (sameNonEmptyCommands(config.profiles.fast, config.profiles.full)) {
    config.profiles.fast = {
      ...(typeof config.profiles.fast?.description === 'string'
        ? { description: config.profiles.fast.description }
        : { description: template.profiles.fast.description }),
      probes: [],
      commands: [],
    }
    notes.push(
      "Disabled fast because it duplicated full. Rebuild target documentation so fast uses the repository's distinct default/primary suite.",
    )
  }

  if (notes.length === 0) {
    return
  }

  const operator =
    config.$operator && typeof config.$operator === 'object'
      ? config.$operator
      : {}
  const priorNotes = Array.isArray(operator.migration_notes)
    ? operator.migration_notes.filter((note) => typeof note === 'string')
    : []

  operator.migration_notes = [...priorNotes, ...notes]
  config.$operator = operator

  mkdirSync(backupRoot, { recursive: true })
  const stamp = new Date()
    .toISOString()
    .replaceAll(':', '-')
    .replaceAll('.', '-')
  const backupPath = path.join(backupRoot, `${stamp}.json`)

  writeFileSync(backupPath, original)
  writeJson(configPath, config)
  process.stdout.write(
    `Migrated repository checks; backup: ${backupPath}\n${notes
      .map((note) => `  - ${note}`)
      .join('\n')}\n`,
  )
}

function writeProject() {
  const source = path.resolve(requiredOption('--source'))
  const destination = path.resolve(requiredOption('--destination'))
  const workspaceId = requiredOption('--workspace-id')
  let config = readJson(source)

  if (existsSync(destination)) {
    config = mergeEmbeddedProjectConfig(config, readJson(destination))
  }

  config.workspace_id = workspaceId
  config.workspace_root = '..'
  config.state_root = 'runtime'
  config.installation_mode = 'embedded'
  delete config.self_development

  if (config.$operator?.note) {
    config.$operator.note = config.$operator.note.replaceAll(
      './bin/pan',
      './.pancreator/bin/pan',
    )
  }

  writeJson(destination, config)
}

async function configureShellAlias() {
  const distRoot = path.resolve(
    option('--dist-root') ??
      path.join(path.dirname(fileURLToPath(import.meta.url)), '..', 'dist'),
  )
  const modulePath = path.join(distRoot, 'src/lib/shell-alias.js')

  if (!existsSync(modulePath)) {
    fail(`Shell alias module is missing: ${modulePath}`)
  }

  const { configureShellAlias: applyShellAlias } = await import(
    pathToFileURL(modulePath).href
  )
  const result = applyShellAlias()

  for (const message of result.messages) {
    process.stdout.write(`${message}\n`)
  }
}

function writeMarker() {
  const destination = path.resolve(requiredOption('--destination'))
  const cursorManifest = readJson(
    path.resolve(requiredOption('--cursor-manifest')),
  )
  const payloadEntries = requiredOption('--payload-entries')
    .split(',')
    .filter(Boolean)

  writeJson(destination, {
    schema_version: 3,
    version: requiredOption('--version'),
    source_commit: requiredOption('--source-commit'),
    source_dirty: requiredOption('--source-dirty') === 'true',
    source_indexed: requiredOption('--source-indexed') === 'true',
    installed_at: requiredOption('--installed-at'),
    payload_entries: payloadEntries,
    cursor_files: cursorManifest.cursor_files,
  })
}

const command = process.argv[2]

if (command === 'project-cursor') {
  projectCursor()
} else if (command === 'write-project') {
  writeProject()
} else if (command === 'write-marker') {
  writeMarker()
} else if (command === 'migrate-repository-checks') {
  migrateRepositoryChecks()
} else if (command === 'preserve-language-governance') {
  preserveLanguageGovernance()
} else if (command === 'configure-shell-alias') {
  await configureShellAlias()
} else {
  fail(`Unknown install support command: ${command ?? '(missing)'}`)
}
