#!/usr/bin/env bash
set -euo pipefail

MAX_CAPTURE_BYTES=$((16 * 1024 * 1024))

usage() {
  echo "Usage: bin/run-quiet -- <command> [args...]" >&2
}

is_verbose() {
  case "${PAN_VERBOSE:-}" in
    1 | true | yes | TRUE | YES) return 0 ;;
    *) return 1 ;;
  esac
}

if [[ $# -eq 0 ]] || [[ "${1:-}" != '--' ]]; then
  usage
  exit 1
fi

shift
if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

command=("$@")

if is_verbose; then
  exec "${command[@]}"
fi

stdout_file="$(mktemp)"
stderr_file="$(mktemp)"
trap 'rm -f "$stdout_file" "$stderr_file"' EXIT

set +e
"${command[@]}" >"$stdout_file" 2>"$stderr_file"
status=$?
set -e

if [[ "$status" -eq 0 ]]; then
  exit 0
fi

stdout_bytes="$(wc -c <"$stdout_file" | tr -d ' ')"
stderr_bytes="$(wc -c <"$stderr_file" | tr -d ' ')"
truncated=0

if [[ "$stdout_bytes" -gt "$MAX_CAPTURE_BYTES" ]]; then
  tail -c "$MAX_CAPTURE_BYTES" "$stdout_file" >"${stdout_file}.tail"
  mv "${stdout_file}.tail" "$stdout_file"
  truncated=1
fi

if [[ "$stderr_bytes" -gt "$MAX_CAPTURE_BYTES" ]]; then
  tail -c "$MAX_CAPTURE_BYTES" "$stderr_file" >"${stderr_file}.tail"
  mv "${stderr_file}.tail" "$stderr_file"
  truncated=1
fi

if [[ "$truncated" -eq 1 ]]; then
  echo "[quiet runner] output truncated to the last ${MAX_CAPTURE_BYTES} bytes" >&2
fi

cat "$stdout_file"
cat "$stderr_file" >&2
exit "$status"
