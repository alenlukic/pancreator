# --- Cursor ---

# Runtime IDE surface; regenerated via `pan cursor-sync` or `pan init --apply`.
.cursor/

# Local-only operator overrides; indexing policy lives in .cursorindexingignore (tracked).
.cursorignore

# --- Local control plane ---

# Stray runtime workspace when project_root != harness root (see pancreator/.pan/).
.pan/

pancreator/.pan/

# --- Local inbox ---

pancreator/lib/inbox/

# --- Internal product docs (local-only; explicit-read; not in git index) ---

pancreator/.docs/

# --- Ephemeral runtime workspaces ---

pancreator/lib/memory/checkpoints/
pancreator/lib/internal/packages/@pancreator/env-isolation/src/.tmp-ports-*/

# Operator-local calibration traces (CI uses baselines/findings/raw only)
pancreator/tests/compliance/context-usage/calibration/traces/**
!pancreator/tests/compliance/context-usage/calibration/traces/.gitkeep

# Committed prototype fixtures (negate global .work/archive ignores)
!pancreator/tests/compliance/context-usage/fixtures/task-low/work/
!pancreator/tests/compliance/context-usage/fixtures/task-low/work/**
!pancreator/tests/compliance/context-usage/fixtures/task-high/work/
