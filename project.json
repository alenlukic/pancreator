      }
    },
    "auto": {
      "summary": "Cursor-managed routing except for the bounded coding workhorse.",
      "personas": {
        "tech-lead": "grok-4.5[effort=high,fast=false]",
        "decomposer": "grok-4.5[effort=high,fast=false]",
        "reviewer": "grok-4.5[effort=high,fast=false]",
