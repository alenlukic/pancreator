      "personas": {
        "tech-lead": "gpt-5.6-terra[context=272k,reasoning=high,fast=false]",
        "decomposer": "gpt-5.6-terra[context=272k,reasoning=high,fast=false]",
        "reviewer": "gpt-5.6-terra[context=272k,reasoning=high,fast=false]",
        "qa-tester": "gpt-5.3-codex[reasoning=high,fast=false]"
      }
    },
    "default": {
      "summary": "Balance of focused coding, strong review, and frontier planning.",
      "personas": {
        "tech-lead": "gpt-5.6-terra[context=272k,reasoning=xhigh,fast=false]",
        "decomposer": "gpt-5.6-terra[context=272k,reasoning=high,fast=false]",
        "reviewer": "claude-opus-4-8[thinking=true,context=300k,effort=high,fast=false]",
        "qa-tester": "grok-4.5[effort=xhigh,fast=false]"
      }
    },
    "complex": {
