{
  "schema_version": 1,
  "workspace_id": "pancreator-self-dev",
  "workspace_root": ".",
  "state_root": "runtime",
  "tracking": {
    "include": ["**/*"],
    "exclude": [
      "dist/**",
      "node_modules/**",
      "coverage/**",
      "package-lock.json",
      "tsconfig.tsbuildinfo"
    ]
  },
  "active_config": "complex",
  "defaults": {
    "orchestrator": "grok-4.5[effort=high,fast=false]",
    "coder": "composer-2.5[fast=false]",
    "librarian": "grok-4.5[effort=high,fast=false]",
    "release-steward": "auto",
    "investigator": "gpt-5.6-sol[context=272k,reasoning=high,fast=false]",
    "harness-technician": "grok-4.5[effort=high,fast=false]",
    "repo-technician": "grok-4.5[effort=high,fast=false]",
